# CONFIGURACIÓN DE SUPABASE PARA VITE + REACT
# Duplica este archivo, cámbiale el nombre a '.env' y reemplaza los valores de ejemplo
# con tus credenciales reales del panel de control de Supabase (Settings -> API).

VITE_SUPABASE_URL=https://tu-proyecto-id.supabase.co
VITE_SUPABASE_ANON_KEY=tu-clave-anon-de-supabase-publica-jwt
